SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-2.pooler.supabase.com:5432/postgres

